{
  "name": "apple-fm-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Apple's on-device Foundation Models (SystemLanguageModel)",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "build/apple_fm_sdk_napi.node",
    "build/libFoundationModels.dylib",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "build:native": "./build.sh",
    "build:napi": "cd native && cargo build --release && cp target/release/libapple_fm_sdk_napi.dylib ../build/apple_fm_sdk_napi.node",
    "build:all": "bun run build:native && bun run build:napi && bun run build",
    "build:release": "bun run build:all && bun run check && node scripts/verify-package.mjs",
    "prepack": "bun run build:release",
    "pack:check": "npm pack --dry-run",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --testPathPattern='tests/(?!integration)'",
    "clean": "rm -rf dist",
    "clean:all": "rm -rf dist build"
  },
  "keywords": [
    "apple",
    "apple-intelligence",
    "foundation-models",
    "on-device",
    "ai",
    "language-model",
    "macos",
    "ffi",
    "typescript"
  ],
  "author": "Tariq West",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tariqwest/ts-apple-fm-sdk.git"
  },
  "homepage": "https://github.com/tariqwest/ts-apple-fm-sdk#readme",
  "bugs": {
    "url": "https://github.com/tariqwest/ts-apple-fm-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64"
  ],
  "dependencies": {
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}